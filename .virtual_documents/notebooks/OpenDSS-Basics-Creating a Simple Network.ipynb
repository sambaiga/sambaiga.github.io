def create_opendss_model():
    dss.text("ClearAll")
    #dss.text("Set DefaultBaseFrequency=50")  #frequency of the system 50 Hz
    dss.text(' New circuit.UtilityDemo basekV=132 pu=1.0 angle=0 frequency=50 phases=3') # define new network

    ## 1. define substation transformer
    dss.text('new transformer.SS phases=3  windings=2  buses=(sourcebus, A)  conns=(wye, wye)  kvs=(132, 33)  kvas=(30000, 30000) %loadloss=0 xhl=12.5 maxtap=1.05 mintap=0.85')
    #Transformer name, number of phases, number of windings, percent reactance high-to-low, buses, connection, voltage rating, kVA rating, percent resistance

    dss.text('new regcontrol.SS transformer=SS winding=2 tapwinding=1 vreg=(100) ptratio=(33000 3 sqrt / 100 /) band=1')
    #this band will lead to a final voltage within 0.995-1.005pu
    
    ## 2. Define the line  configurations (feeder)
    dss.text(' new linecode.ABC nphases=3 R1=2.13444 X1=1.554003 units=km')
    #Configuration name, number of phases, resistance, reactance, unit

    # 3. Define line segment
    dss.text('new line.lineA-B phases=3 bus1=A bus2=B length=1  units=km linecode=ABC')
    # Line segment name, number of phases, 1st bus, 2nd bus Length, unit, line configuration

    #define loads with a variety of phase configurations.
    
    dss.text(f'new loadshape.daily npts=189 interval=1.0 csvfile={load_file}')
    
    dss.text('new load.loadB phases=3 bus1=B kV=33 kW=5000 kvar=1640  daily=daily status=variable')
    #Load name, number of phses,  bus, kV rating, active power, reactive power, mode Note: loads are being modelled as 'daily' loads with a given load shape, so below the "mode" command has to say 'daily' as well
    
    dss.text('new monitor.Vbb element=transformer.SS terminal=2 mode=0')
    dss.text('new monitor.SS element=transformer.SS terminal=1 mode=1 ppolar=no')
    dss.text('new monitor.Tap element=transformer.SS terminal=1 mode=2')
    
    
    #Meters (to check energy exports/imports, losses)
    dss.text('new energymeter.Grid element=transformer.SS terminal=1')
    dss.text('new energymeter.mloadB element=line.lineA-B terminal=2')
    
    dss.text('set controlmode=static')
    dss.text('set mode=daily')
    dss.text('solve')





load_file='F'





create_opendss_model()


tap_monitor = dss.text('export monitors Tap')
tap_monitor =pd.read_csv(tap_monitor)





